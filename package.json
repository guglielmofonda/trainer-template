{
  "name": "trainer-template",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A progressive-overload, periodized strength training platform. The engine (periodization + autoregulated progression) is the core.",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "engine:demo": "tsx scripts/demo.ts",
    "hevy:import": "tsx --env-file-if-exists=.env.local scripts/hevy-import.ts",
    "hevy:export": "tsx --env-file-if-exists=.env.local scripts/hevy-export.ts",
    "hevy:daily": "tsx --env-file-if-exists=.env.local scripts/hevy-daily.ts",
    "weekly:advance": "tsx --env-file-if-exists=.env.local scripts/weekly-advance.ts",
    "program:push": "tsx scripts/program-push.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@vercel/blob": "^2.6.1",
    "geist": "^1.7.2",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.5",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

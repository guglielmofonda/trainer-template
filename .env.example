# Optional — enables the conversational Training Coach (Claude Opus 4.8) with its
# tool harness: it reads your schedule/program/logs/Hevy history, edits the plan
# (e.g. restructures back-to-back days), and pushes routines to Hevy on your
# say-so (the Hevy tools also need HEVY_API_KEY below). Without it, the coach runs
# in a deterministic "offline" mode that still reads your real program + logs +
# volume analysis. The rest of the app needs no keys.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — lets the app calibrate your starting weights and tune the plan from
# your real Hevy workout history (Configuration → "Import from Hevy", or the CLI
# `npm run hevy:import`). Get a key at hevy.com → Settings → API (requires Hevy
# Pro). You can also paste the key directly in the UI instead of setting it here.
HEVY_API_KEY=

# Vercel injects this when a private Blob store is connected. Production uses
# it for durable program, log, and coach-conversation writes; local development
# keeps the same data in data/store.json.
BLOB_READ_WRITE_TOKEN=

# Optional — enables the Hevy webhook receiver at /api/hevy/webhook, which Hevy
# calls when you save a new workout. Set a random secret and register the URL in
# Hevy as https://<host>/api/hevy/webhook?token=<this-secret>. The endpoint is
# disabled until this is set. (A localhost dev server needs a tunnel, e.g.
# `ngrok http 3000`, to receive Hevy's POSTs.)
HEVY_WEBHOOK_SECRET=
# Set to "true" to auto-apply confident starting-weight updates after each new
# workout (never touches a locked program). Off by default — the webhook only
# acknowledges and logs unless you opt in.
HEVY_WEBHOOK_AUTO_APPLY=

# Required on Vercel — gates the hosted app behind a password login.
# Optional locally; if omitted outside Vercel, the app stays open for development.
APP_PASSWORD=

# Optional but recommended on Vercel — random value used to sign the login cookie.
# If omitted, APP_PASSWORD is used as the signing secret.
APP_SESSION_SECRET=
